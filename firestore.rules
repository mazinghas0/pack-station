rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자 계정 (로그인/계정관리용)
    match /users/{userId} {
      allow read, write: if true;
    }

    // 주문 데이터
    match /orders/{docId} {
      allow read, write: if true;
    }

    // 셀 (스테이션 작업)
    match /cells/{docId} {
      allow read, write: if true;
    }

    // 업로드 기록
    match /uploads/{docId} {
      allow read, write: if true;
    }

    // 운송장 중복 방지 락
    match /waybillLocks/{docId} {
      allow read, write: if true;
    }

    // 앱 설정 (활성 배차 등)
    match /config/{docId} {
      allow read, write: if true;
    }

    // 데일리 브리핑
    match /dailyReports/{docId} {
      allow read, write: if true;
    }

    // 스테이션 설정
    match /stations/{docId} {
      allow read, write: if true;
    }

    // 그 외 모든 컬렉션 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
